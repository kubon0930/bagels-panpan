# ============================================================
# Bagels Panpan. 予約販売システム 環境変数
# .env.local にコピーして値を設定してください（未設定でも公式サイトは動きます）
# ============================================================

# サイトの公開URL（Stripe の戻り先などに使用）
NEXT_PUBLIC_SITE_URL=https://bagels-panpan.vercel.app

# --- Supabase（予約システムを有効化するのに必須）---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用。絶対に公開しないこと。
SUPABASE_SERVICE_ROLE_KEY=

# --- 決済モード ---
# reservation_only … 予約のみ（店頭支払い）。Stripe不要。
# stripe           … オンライン事前決済。下の Stripe キーも必要。
NEXT_PUBLIC_PAYMENT_MODE=reservation_only

# --- Stripe（NEXT_PUBLIC_PAYMENT_MODE=stripe の場合のみ）---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- メール通知（任意・Resend）。未設定ならメールは送信されません ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# 店舗が新規予約通知を受け取るメールアドレス
SHOP_NOTIFICATION_EMAIL=

# --- アクセス解析・Search Console（任意）---
# GA4 の測定ID（例: G-XXXXXXXXXX）。未設定なら計測は無効。本番環境でのみ計測されます。
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Search Console の所有権確認コード（HTMLタグ方式の content 値）
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
